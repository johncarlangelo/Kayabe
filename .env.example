# draft .env example

# KAYABÉ - DRAFT ENVIRONMENT VARIABLES
# Monorepo: Next.js (web) + NestJS (api)

# GENERAL APP CONFIG

NODE_ENV=development

# Used for shared config or base URLs if needed
APP_NAME=Kayabé


# FRONTEND (Next.js - apps/web)

# Public URL of backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Socket.io server URL (can be same as API)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Optional: app base URL (useful for auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# BACKEND (NestJS - apps/api)

# Server port
PORT=3001

# Frontend URL (for CORS + redirects)
FRONTEND_URL=http://localhost:3000

# API base URL (useful for email links, callbacks)
API_URL=http://localhost:3001


# DATABASE (Prisma - planned)

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/kayabe_db
# postgres → username
# password → your local DB password
# localhost → your machine
# 5432 → default Postgres port
# kayabe_db → database name

# AUTH (future-ready)

# JWT secret (IMPORTANT: keep strong in real env)
JWT_SECRET=your_super_secret_jwt_key

# JWT expiration
JWT_EXPIRES_IN=


# SOCKET.IO

SOCKET_CORS_ORIGIN=http://localhost:3000


# OPTIONAL FEATURES (future sprint placeholders)

# Email service (for notifications, password reset, etc.)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_password

# File uploads (if you later use S3 or similar)
# STORAGE_BUCKET_NAME=
# STORAGE_REGION=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=